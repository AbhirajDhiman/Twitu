# --- Core ---
GEMINI_API_KEY=your_gemini_api_key

# --- Twitter/X credentials ---
# Preferred names
TWITTER_CONSUMER_KEY=your_twitter_consumer_key
TWITTER_CONSUMER_KEY_SECRET=your_twitter_consumer_key_secret
# Backward-compatible alternatives (optional)
# TWITTER_API_KEY=your_twitter_api_key
# TWITTER_API_SECRET=your_twitter_api_secret

TWITTER_ACCESS_TOKEN=your_twitter_access_token
TWITTER_ACCESS_TOKEN_SECRET=your_twitter_access_token_secret

# --- MCP server network ---
MCP_HOST=127.0.0.1
MCP_PORT=3001

# --- Deployment hardening ---
# AUTH_MODE: none | apikey | jwt
AUTH_MODE=apikey

# Used when AUTH_MODE=apikey
MCP_API_KEY_HEADER=x-api-key
MCP_API_KEY=replace_with_a_long_random_secret

# Used when AUTH_MODE=jwt
JWT_SECRET=replace_with_jwt_signing_secret
JWT_ISSUER=twitu
JWT_AUDIENCE=twitu-clients
# Client-side bearer token to call MCP when AUTH_MODE=jwt
MCP_JWT_TOKEN=replace_with_signed_jwt_token

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=120

# Optional for reverse proxies / cloud ingress
# TRUST_PROXY=1
